        "# @title\n",
        "'''import time\n",
        "import pandas as pd\n",
        "from ping3 import ping\n",
        "import os\n",
        "\n",
        "# Configuration\n",
        "LOG_FILE = \"network_log.csv\"\n",
        "BUFFER_SIZE = 30  # Write to disk every 30 checks\n",
        "data_buffer = []  # In-memory buffer\n",
        "\n",
        "def save_to_csv(buffer):\n",
        "    df = pd.DataFrame(buffer)\n",
        "    # Append to file; write header only if file doesn't exist\n",
        "    header = not os.path.exists(LOG_FILE)\n",
        "    df.to_csv(LOG_FILE, mode='a', index=False, header=header)\n",
        "    print(f\"Data flushed to {LOG_FILE}\")\n",
        "\n",
        "def collect_metrics(dest=\"8.8.8.8\"):\n",
        "    global data_buffer\n",
        "    prev_latency = None\n",
        "\n",
        "    while True:\n",
        "        latency = ping(dest, unit='ms')\n",
        "        timestamp = pd.Timestamp.now() # Use Pandas Timestamps\n",
        "\n",
        "        # Logic for metrics\n",
        "        if latency is None:\n",
        "            entry = {\"time\": timestamp, \"status\": \"Down\", \"loss\": 1, \"latency\": 0, \"jitter\": 0}\n",
        "            prev_latency = None # Reset on loss\n",
        "        else:\n",
        "            jitter = abs(latency - prev_latency) if prev_latency is not None else 0\n",
        "            entry = {\"time\": timestamp, \"status\": \"Up\", \"loss\": 0, \"latency\": latency, \"jitter\": jitter}\n",
        "            prev_latency = latency\n",
        "\n",
        "        data_buffer.append(entry)\n",
        "\n",
        "        # Batch write to disk to save resources\n",
        "        if len(data_buffer) >= BUFFER_SIZE:\n",
        "            save_to_csv(data_buffer)\n",
        "            data_buffer = [] # Clear buffer\n",
        "\n",
        "        time.sleep(2)'''"
      ],
