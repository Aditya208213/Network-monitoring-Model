    {
      "cell_type": "markdown",
      "metadata": {
        "id": "e4bdb982"
      },
      "source": [
        "### Step 1: Save the Streamlit app code to a Python file\n",
        "\n",
        "This command writes the Python code directly into a file named `app.py`. Streamlit needs a file to run."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "dc098d0d"
      },
      "source": [
        "%%writefile app.py\n",
        "import streamlit as st\n",
        "import sqlite3\n",
        "import pandas as pd\n",
        "import plotly.express as px\n",
        "from datetime import datetime\n",
        "\n",
        "st.set_page_config(layout=\"wide\")\n",
        "st.title(\"24x7 Network Monitor\")\n",
        "\n",
        "# Load data from SQLite\n",
        "conn = sqlite3.connect('network_stats.db')\n",
        "df = pd.read_sql_query(\"SELECT * FROM metrics\", conn)\n",
        "\n",
        "# Convert timestamp to datetime objects and ensure correct format\n",
        "df['timestamp'] = pd.to_datetime(df['timestamp'])\n",
        "\n",
        "# Date Selector\n",
        "# Get unique dates from the dataframe to populate the date_input\n",
        "if not df.empty:\n",
        "    unique_dates = sorted(df['timestamp'].dt.date.unique())\n",
        "    if unique_dates:\n",
        "        # Set default to the latest date if available, otherwise today\n",
        "        default_date = unique_dates[-1] if unique_dates else datetime.today().date()\n",
        "        selected_date = st.date_input(\"Select Date\", value=default_date)\n",
        "    else:\n",
        "        selected_date = st.date_input(\"Select Date\") # Fallback if no dates in df\n",
        "else:\n",
        "    selected_date = st.date_input(\"Select Date\") # Fallback for empty df\n",
        "\n",
        "# Filtering Logic by date\n",
        "filtered_df = df[df['timestamp'].dt.date == selected_date]\n",
        "\n",
        "if filtered_df.empty:\n",
        "    st.warning(f\"No data available for {selected_date}. Please select another date or add more data.\")\n",
        "else:\n",
        "    # Get unique target IPs for selection\n",
        "    all_target_ips = filtered_df['target_ip'].unique().tolist()\n",
        "    # Allow user to select multiple target IPs\n",
        "    selected_target_ips = st.multiselect(\n",
        "        \"Select Target IPs\",\n",
        "        options=all_target_ips,\n",
        "        default=all_target_ips # Default to all selected\n",
        "    )\n",
        "\n",
        "    if not selected_target_ips:\n",
        "        st.warning(\"Please select at least one target IP.\")\n",
        "    else:\n",
        "        # Further filter by selected target IPs\n",
        "        final_filtered_df = filtered_df[filtered_df['target_ip'].isin(selected_target_ips)]\n",
        "\n",
        "        if final_filtered_df.empty:\n",
        "            st.warning(f\"No data for selected IPs on {selected_date}.\")\n",
        "        else:\n",
        "            # Define the actual monitoring interval used in the data collection script\n",
        "            MONITOR_INTERVAL_APP = 0.5 # Must match the MONITOR_INTERVAL in lzqjodjaW8PQ\n",
        "\n",
        "            # Calculate cumulative uptime percentage for plotting\n",
        "            def calculate_cumulative_uptime(group_df):\n",
        "                group_df = group_df.sort_values(by='timestamp')\n",
        "\n",
        "                # Each record covers an interval defined by MONITOR_INTERVAL_APP\n",
        "                group_df['interval_up_seconds'] = group_df['status'].apply(lambda x: MONITOR_INTERVAL_APP if x == 'Up' else 0)\n",
        "                group_df['interval_total_seconds'] = MONITOR_INTERVAL_APP\n",
        "\n",
        "                group_df['cumulative_up_seconds'] = group_df['interval_up_seconds'].cumsum()\n",
        "                group_df['cumulative_total_seconds'] = group_df['interval_total_seconds'].cumsum()\n",
        "\n",
        "                # Handle cases where cumulative_total_seconds might be zero initially\n",
        "                group_df['cumulative_uptime_percentage'] = (group_df['cumulative_up_seconds'] / group_df['cumulative_total_seconds']) * 100\n",
        "                group_df['cumulative_uptime_percentage'] = group_df['cumulative_uptime_percentage'].fillna(0)\n",
        "                return group_df\n",
        "\n",
        "            final_filtered_df = final_filtered_df.groupby('target_ip', group_keys=False).apply(calculate_cumulative_uptime)\n",
        "\n",
        "            # --- Uptime Percentage Calculation --- added for user request\n",
        "            st.subheader(\"Uptime Summary (for selected date)\")\n",
        "            uptime_summary = []\n",
        "            for ip in selected_target_ips:\n",
        "                ip_df = final_filtered_df[final_filtered_df['target_ip'] == ip]\n",
        "                #\n",
        "                The last cumulative percentage for the day is the daily uptime\n",
        "                if not ip_df.empty:\n",
        "                    daily_uptime_pct = ip_df['cumulative_uptime_percentage'].iloc[-1]\n",
        "                else:\n",
        "                    daily_uptime_pct = 0.0\n",
        "\n",
        "                uptime_summary.append({\n",
        "                    \"Target IP\": ip,\n",
        "                    \"Uptime Percentage\": f\"{daily_uptime_pct:.2f}%\"\n",
        "                })\n",
        "            st.dataframe(pd.DataFrame(uptime_summary))\n",
        "            # --- End Uptime Percentage Calculation ---\n",
        "\n",
        "            # Plotting Latency & Jitter and Cumulative Uptime for selected targets\n",
        "            fig = px.line(\n",
        "                final_filtered_df,\n",
        "                x='timestamp',\n",
        "                y=['latency', 'jitter', 'cumulative_uptime_percentage'], # Added cumulative_uptime_percentage\n",
        "                color='target_ip', # This is the key change to show separate lines\n",
        "                title=f\"Network Performance for {', '.join(selected_target_ips)} on {selected_date}\",\n",
        "                hover_data={'target_ip': True, 'latency': ':.2f', 'jitter': ':.2f', 'status': True, 'cumulative_uptime_percentage': ':.2f'}\n",
        "            )\n",
        "            fig.update_layout(hovermode=\"x unified\")\n",
        "            st.plotly_chart(fig, use_container_width=True)\n",
        "\n",
        "            # Display raw data for inspection (optional)\n",
        "            st.subheader(\"Raw Data for Selected Date and IPs\")\n",
        "            # Drop the intermediate calculation columns before displaying the dataframe\n",
        "            cols_to_drop = ['interval_up_seconds', 'interval_total_seconds', 'cumulative_up_seconds', 'cumulative_total_seconds']\n",
        "            display_df = final_filtered_df.drop(columns=[col for col in cols_to_drop if col in final_filtered_df.columns])\n",
        "            st.dataframe(display_df)\n",
        "\n",
        "            # Export to CSV/Excel\n",
        "            if st.button('Export to CSV'):\n",
        "                # Ensure the filename is valid and avoids special characters\n",
        "                safe_date_str = selected_date.strftime('%Y-%m-%d')\n",
        "                csv_filename = f\"report_{safe_date_str}_selected_ips.csv\"\n",
        "                final_filtered_df.to_csv(csv_filename, index=False)\n",
        "                st.success(f\"Exported successfully to {csv_filename}!\")\n",
        "                # Provide a download link\n",
        "                with open(csv_filename, \"rb\") as file:\n",
        "                    st.download_button(\n",
        "                        label=\"Download CSV\",\n",
        "                        data=file,\n",
        "                        file_name=csv_filename,\n",
        "                        mime=\"text/csv\",\n",
        "                    )"
      ],
      "execution_count": null,
      "outputs": []
    },
