        "import streamlit as st\n",
        "import sqlite3\n",
        "import pandas as pd\n",
        "import plotly.express as px\n",
        "\n",
        "st.title(\"24x7 Network Monitor\")\n",
        "\n",
        "# Load data from SQLite\n",
        "conn = sqlite3.connect('network_stats.db')\n",
        "df = pd.read_sql_query(\"SELECT * FROM metrics\", conn)\n",
        "\n",
        "# Date Selector\n",
        "selected_date = st.date_input(\"Select Date\")\n",
        "\n",
        "# Filtering Logic\n",
        "filtered_df = df[df['timestamp'].str.contains(str(selected_date))]\n",
        "\n",
        "# Plotting Latency & Jitter\n",
        "fig = px.line(filtered_df, x='timestamp', y=['latency', 'jitter'], title=\"Network Performance\")\n",
        "st.plotly_chart(fig)\n",
        "\n",
        "# Export to CSV/Excel\n",
        "if st.button('Export to CSV'):\n",
        "    filtered_df.to_csv(f\"report_{selected_date}.csv\")\n",
        "    st.success(\"Exported successfully!\")"
      ],
