        "import sqlite3\n",
        "import pytz\n",
        "from datetime import datetime\n",
        "\n",
        "def save_to_db(target_ip, status, loss, latency, jitter, current_uptime_duration, current_downtime_duration, db_name='network_stats.db'):\n",
        "    conn = sqlite3.connect(db_name)\n",
        "    cursor = conn.cursor()\n",
        "\n",
        "    # Create table if it doesn't exist\n",
        "    cursor.execute('''\n",
        "        CREATE TABLE IF NOT EXISTS metrics (\n",
        "            timestamp DATETIME,\n",
        "            target_ip TEXT,\n",
        "            status TEXT,\n",
        "            loss INTEGER,\n",
        "            latency REAL,\n",
        "            jitter REAL,\n",
        "            current_uptime_duration REAL,\n",
        "            current_downtime_duration REAL\n",
        "        )\n",
        "    ''')\n",
        "    ist = pytz.timezone('Asia/Kolkata')\n",
        "    timestamp = datetime.now(ist).strftime('%Y-%m-%d %H:%M:%S')\n",
        "    cursor.execute(\"INSERT INTO metrics (timestamp, target_ip, status, loss, latency, jitter, current_uptime_duration, current_downtime_duration) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\",\n",
        "                   (timestamp, target_ip, status, loss, latency, jitter, current_uptime_duration, current_downtime_duration))\n",
        "    conn.commit()\n",
        "    conn.close()"
      ],
      "execution_count": null,
      "outputs": []
    },
