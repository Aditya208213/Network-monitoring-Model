        "### Step 2: Install and Authenticate ngrok\n",
        "\n",
        "`ngrok` is a tool that allows you to expose a local web server to the internet. We'll use it to make your Streamlit app accessible via a public URL. You'll need to get an `NGROK_AUTH_TOKEN` from [ngrok.com](https://ngrok.com/signup) and add it to your Colab secrets."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "6e141d01"
      },
      "source": [
        "from google.colab import userdata\n",
        "import os\n",
        "\n",
        "# Install ngrok first to ensure pyngrok is available\n",
        "!pip install pyngrok\n",
        "\n",
        "# Get your ngrok authentication token from Colab secrets\n",
        "NGROK_AUTH_TOKEN = userdata.get('NGROK_AUTH_TOKEN')\n",
        "\n",
        "# Authenticate ngrok\n",
        "!ngrok authtoken $NGROK_AUTH_TOKEN"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "84967297"
      },
      "source": [
        "from google.colab import userdata\n",
        "from google.colab.userdata import SecretNotFoundError\n",
        "\n",
        "try:\n",
        "    NGROK_AUTH_TOKEN = userdata.get('NGROK_AUTH_TOKEN')\n",
        "    print(\"NGROK_AUTH_TOKEN is accessible. You can now proceed with ngrok setup.\")\n",
        "except SecretNotFoundError:\n",
        "    NGROK_AUTH_TOKEN = None\n",
        "    print(\"NGROK_AUTH_TOKEN is NOT accessible. Please ensure it's added to Colab secrets and notebook access is enabled.\")"
