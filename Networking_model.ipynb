    {
      "cell_type": "code",
      "source": [
        "import time\n",
        "import pandas as pd\n",
        "from ping3 import ping\n",
        "from concurrent.futures import ThreadPoolExecutor #for pinging multiple ip address parallely\n",
        "from datetime import datetime\n",
        "\n",
        "# Your list of targets\n",
        "TARGETS = [\"35.186.224.24\", \"142.250.67.206\", \"142.250.206.142\"]\n",
        "\n",
        "# Monitoring interval in seconds\n",
        "MONITOR_INTERVAL = 0.5\n",
        "\n",
        "# Dictionary to store previous latencies for jitter calculation for each target\n",
        "# Ensure prev_latencies is initialized only once per kernel session, or if TARGETS changes\n",
        "if 'prev_latencies' not in globals() or not isinstance(prev_latencies, dict) or set(prev_latencies.keys()) != set(TARGETS):\n",
        "    prev_latencies = {target: None for target in TARGETS}\n",
        "\n",
        "# Dictionary to store the last known status and the timestamp of that status change\n",
        "# Initialize with 'Unknown' status and current time for all targets\n",
        "if 'last_status_info' not in globals() or not isinstance(last_status_info, dict) or set(last_status_info.keys()) != set(TARGETS):\n",
        "    last_status_info = {target: {'status': 'Unknown', 'timestamp': datetime.now()} for target in TARGETS}\n",
        "\n",
        "def get_target_stats(dest):\n",
        "    latency = ping(dest, unit='ms')\n",
        "    status = \"Up\" if latency is not None else \"Down\"\n",
        "    latency = latency if latency is not None else 0\n",
        "    return {\"target\": dest, \"latency\": latency, \"status\": status}\n",
        "\n",
        "if 'stats_tracker' not in globals():\n",
        "    stats_tracker = {target: {'up_seconds': 0, 'total_seconds': 0} for target in TARGETS}\n",
        "\n",
        "def collect_all():\n",
        "    global prev_latencies\n",
        "    global last_status_info\n",
        "    global stats_tracker\n",
        "\n",
        "    # Use ThreadPoolExecutor to ping all IPs in parallel\n",
        "    with ThreadPoolExecutor(max_workers=len(TARGETS)) as executor:\n",
        "        results = list(executor.map(get_target_stats, TARGETS))\n",
        "\n",
        "    # Save to DB and calculate jitter, uptime, downtime\n",
        "    for row in results:\n",
        "        target_ip = row['target']\n",
        "        current_latency = row['latency']\n",
        "        current_status = row['status']\n",
        "        loss = 1 if current_status == \"Down\" else 0\n",
        "\n",
        "        # Calculate jitter\n",
        "        prev_latency = prev_latencies.get(target_ip)\n",
        "        if prev_latency is not None and current_status == \"Up\":\n",
        "            jitter = abs(current_latency - prev_latency)\n",
        "        else:\n",
        "            jitter = 0\n",
        "\n",
        "        # Update prev_latencies for the next iteration\n",
        "        prev_latencies[target_ip] = current_latency if current_status == \"Up\" else None\n",
        "\n",
        "        # Calculate uptime and downtime durations\n",
        "        last_info = last_status_info[target_ip]\n",
        "        previous_status = last_info['status']\n",
        "        last_status_timestamp = last_info['timestamp']\n",
        "        current_time = datetime.now()\n",
        "\n",
        "        # Calculate the duration in seconds since the last status check\n",
        "        time_since_last_change = (current_time - last_status_timestamp).total_seconds()\n",
        "\n",
        "        current_uptime_duration = 0\n",
        "        current_downtime_duration = 0\n",
        "\n",
        "        if current_status == \"Up\":\n",
        "            if previous_status == \"Up\":\n",
        "                current_uptime_duration = time_since_last_change\n",
        "            else: # Status changed from Down/Unknown to Up\n",
        "                current_uptime_duration = 0 # New uptime cycle starts\n",
        "                # Reset downtime duration from previous cycle\n",
        "        else: # current_status == \"Down\"\n",
        "            if previous_status == \"Down\":\n",
        "                current_downtime_duration = time_since_last_change\n",
        "            else: # Status changed from Up/Unknown to Down\n",
        "                current_downtime_duration = 0 # New downtime cycle starts\n",
        "                # Reset uptime duration from previous cycle\n",
        "\n",
        "        # Update last_status_info for the next iteration\n",
        "        if current_status != previous_status:\n",
        "            last_status_info[target_ip] = {'status': current_status, 'timestamp': current_time}\n",
        "        else:\n",
        "            last_status_info[target_ip]['timestamp'] = current_time\n",
        "\n",
        "        # Update stats_tracker within the loop for each target_ip\n",
        "        stats_tracker[target_ip]['total_seconds'] += MONITOR_INTERVAL # Use MONITOR_INTERVAL\n",
        "        if current_status == \"Up\":\n",
        "            stats_tracker[target_ip]['up_seconds'] += MONITOR_INTERVAL\n",
        "\n",
        "        # Calculate percentage for each target_ip\n",
        "        if stats_tracker[target_ip]['total_seconds'] > 0:\n",
        "            uptime_pct = (stats_tracker[target_ip]['up_seconds'] /\n",
        "                          stats_tracker[target_ip]['total_seconds']) * 100\n",
        "        else:\n",
        "            uptime_pct = 0.0\n",
        "\n",
        "        print(f\"Target: {target_ip} | Uptime: {uptime_pct:.2f}%\")\n",
        "\n",
        "        save_to_db(target_ip=target_ip, status=current_status, loss=loss, latency=current_latency, jitter=jitter,\n",
        "                   current_uptime_duration=current_uptime_duration, current_downtime_duration=current_downtime_duration)\n",
        "    print(f\"Collected and saved data for targets: {[r['target'] for r in results]}\")\n",
        "\n",
        "while True:\n",
        "    collect_all()\n",
        "    time.sleep(MONITOR_INTERVAL)"
      ],
      "metadata": {
        "id": "lzqjodjaW8PQ"
