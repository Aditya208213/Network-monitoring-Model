    {
      "cell_type": "markdown",
      "metadata": {
        "id": "96931313"
      },
      "source": [
        "### Step 3: Run the Streamlit app and get the public URL\n",
        "\n",
        "This will start the Streamlit app in the background and then use `ngrok` to create a public URL. You can then open this URL in your web browser to interact with the app."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "19245159"
      },
      "source": [
        "import subprocess\n",
        "import time\n",
        "from pyngrok import ngrok\n",
        "\n",
        "# Start Streamlit in the background\n",
        "# Streamlit typically runs on port 8501 by default\n",
        "streamlit_process = subprocess.Popen([\"streamlit\", \"run\", \"app.py\", \"--server.port\", \"8501\", \"--server.enableCORS\", \"false\"])\n",
        "\n",
        "# Give Streamlit a few seconds to start up\n",
        "time.sleep(5)\n",
        "\n",
        "# Open an ngrok tunnel to the Streamlit port\n",
        "tunnel = ngrok.connect(8501)\n",
        "public_url = tunnel.public_url\n",
        "\n",
        "print(f\"Your Streamlit app is running at: {public_url}\")\n",
        "print(\"You can stop the Streamlit process by running: streamlit_process.terminate()\")\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "214b3b91"
      },
      "source": [
        "streamlit_process.terminate()"
      ],
      "execution_count": null,
      "outputs": []
    },
